{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Signal",
  "version": "0.1.0",
  "identifier": "local.signal.desktop",
  "build": {
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Signal",
        "width": 1180,
        "height": 780,
        "minWidth": 940,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Arahe Dev",
    "category": "DeveloperTool",
    "shortDescription": "Local-first agent and phone communication bridge",
    "longDescription": "Signal wraps a local-first daemon, mobile PWA pairing, web push, and worker utilities in one Windows desktop app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/signal-daemon",
      "binaries/signal-cli",
      "binaries/signal-worker"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
